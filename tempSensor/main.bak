/* --- Multiplexer SYNC (chip-select) pins --- */
#define MUX1_SYNC_PIN GPIO_PIN_0 /* PB0 → SYNC1 (U201) */
#define MUX2_SYNC_PIN GPIO_PIN_1 /* PB1 → SYNC2 (U203) */
#define MUX3_SYNC_PIN GPIO_PIN_2 /* PB2 → SYNC3 (U202) */
#define MUX_SYNC_PORT GPIOB

/* --- Topology --- */
#define NUM_MULTIPLEXERS 3
#define NUM_MUX_CHANNELS 32 /* ADG731 S1-S32 per device  */
#define TOTAL_SENSORS (NUM_MULTIPLEXERS * NUM_MUX_CHANNELS) /* 24 */

/* --- ADC --- */
#define ADC_VREF 3.3f
#define ADC_MAX_VALUE 4095.0f

#define MUX_SYNC_DELAY_US 10u /* SYNC assert/deassert hold  */
#define MUX_SETTLE_US 1400u   /* op-amp + mux settle time   */

/* --- CAN message IDs --- */
#define CAN_ID_TEMP_ALERT 0x100u /* Below-threshold alert      */
#define CAN_ID_TEMP_STATS 0x101u /* Min / max / avg statistics */

/* --- Sensor fault voltage bounds --- */
#define VOLT_FAULT_LOW 0.5f  /* below → open circuit        */
#define VOLT_FAULT_HIGH 3.0f /* above → short circuit       */

