/* ---------------------------------------------------------------------------
 * delay_us()
 * Busy-wait microsecond delay using the DWT cycle counter.
 * Much finer granularity than HAL_Delay (1 ms resolution).
 * ---------------------------------------------------------------------------*/
static void delay_us(uint32_t us) {
  /* Enable DWT if not already running */
  if (!(CoreDebug->DEMCR & CoreDebug_DEMCR_TRCENA_Msk)) {
    CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;
    DWT->CYCCNT = 0u;
    DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk;
  }
  uint32_t ticks = us * (SystemCoreClock / 1000000u);
  uint32_t start = DWT->CYCCNT;
  while ((DWT->CYCCNT - start) < ticks)
    ;
}

/* ---------------------------------------------------------------------------
 * ADC_to_Voltage()
 * Converts a 12-bit ADC reading (0-4095) to volts (0-3.3 V).
 * ---------------------------------------------------------------------------*/
static float ADC_to_Voltage(uint32_t adc_value) {
  return ((float)adc_value * ADC_VREF) / ADC_MAX_VALUE;
}

/* ---------------------------------------------------------------------------
 * Voltage_to_Temperature()
 * Converts a sensor voltage to temperature (°C) using linear interpolation
 * on the datasheet lookup table.
 * ---------------------------------------------------------------------------*/
static float Voltage_to_Temperature(float voltage) {
  return (((-6.2994E-9f * voltage + 1.53618E-6f) * voltage - 0.0000569765f) *
              voltage -
          0.0116001f) *
             voltage +
         2.16332f;
}

/* ---------------------------------------------------------------------------
 * MUX_Init()
 * Disables all three multiplexers at startup (SYNC pins HIGH).
 * ---------------------------------------------------------------------------*/
static void MUX_Init(void) {
  HAL_GPIO_WritePin(MUX_SYNC_PORT,
                    MUX1_SYNC_PIN | MUX2_SYNC_PIN | MUX3_SYNC_PIN,
                    GPIO_PIN_SET);
}

/* ---------------------------------------------------------------------------
 * MUX_Enable()
 * Asserts (LOW) or deasserts (HIGH) the SYNC pin for a given multiplexer.
 * ADG731 SYNC is active LOW.
 * ---------------------------------------------------------------------------*/
static void MUX_Enable(uint8_t mux_number, uint8_t enable) {
  GPIO_PinState state = enable ? GPIO_PIN_RESET : GPIO_PIN_SET;
  switch (mux_number) {
  case 0:
    HAL_GPIO_WritePin(MUX_SYNC_PORT, MUX1_SYNC_PIN, state);
    break;
  case 1:
    HAL_GPIO_WritePin(MUX_SYNC_PORT, MUX2_SYNC_PIN, state);
    break;
  case 2:
    HAL_GPIO_WritePin(MUX_SYNC_PORT, MUX3_SYNC_PIN, state);
    break;
  default:
    break;
  }
}

/* ---------------------------------------------------------------------------
 * MUX_SetChannel()
 * Selects a channel (0-32) on the specified ADG731 via SPI.
 *
 * Sequence per ADG731 datasheet:
 *   1. Assert   SYNC LOW
 *   2. Clock in 8-bit word (only lower 3 bits used: A2 A1 A0)
 *   3. Deassert SYNC HIGH  → channel latches on rising edge
 * ---------------------------------------------------------------------------*/
static void MUX_SetChannel(uint8_t mux_number, uint8_t channel) {
  if (channel >= NUM_MUX_CHANNELS || mux_number >= NUM_MULTIPLEXERS)
    return;

  // only chan 1-26 are in use on the third mux
  if (mux_number == 3 && channel > 26) {
    return;
  }

  uint8_t spi_data = channel & 0x07u;

  MUX_Enable(mux_number, 1);
  delay_us(MUX_SYNC_DELAY_US);
  HAL_SPI_Transmit(&hspi1, &spi_data, 1, 10);
  delay_us(MUX_SYNC_DELAY_US);
  MUX_Enable(mux_number, 0);
}

// polls a single channel 2500 times (~1ms) and returns the average of those
// 2500 data points
static float Calculate_Channel_Mean(uint8_t mux, uint8_t chan,
                                    TempStatistics_t *stats) {
  uint32_t adc_mean = 0u;

  if (mux_number >= NUM_MULTIPLEXERS || channel >= NUM_MUX_CHANNELS)
    return 0u;

  /* Disable all muxes before switching channel to prevent glitches */
  HAL_GPIO_WritePin(MUX_SYNC_PORT,
                    MUX1_SYNC_PIN | MUX2_SYNC_PIN | MUX3_SYNC_PIN,
                    GPIO_PIN_SET);

  /* Select the channel */
  MUX_SetChannel(mux_number, channel);

  /* Enable the target mux */
  MUX_Enable(mux_number, 1);

  /* Wait for op-amp filter to settle (hardware-limited minimum) */
  delay_us(MUX_SETTLE_US);

  /* Perform ADC conversion */
  HAL_ADC_Start(&hadc1);
  if (HAL_ADC_PollForConversion(&hadc1, 2u) == HAL_OK) {
    for (uint16_t i = 0; i < 2500; i++) {
      adc_mean += HAL_ADC_GetValue(&hadc1);
    }
  }
  HAL_ADC_Stop(&hadc1);

  /* Deassert mux */
  MUX_Enable(mux_number, 0);

  float temp = Voltage_to_Temperature(ADC_to_Voltage(adc_mean / 2500u));

  if (temp > -998.0f) {
    stats->num_enabled += 1;
  }

  printf("Mux %d, sensor %d: %.3f C", mux, chan, temp);

  return temp;
}

// runs through each of the 90 channels and then returns the mean
// also finds the max/min temp
static void Calculate_Module_Mean(TempStatistics_t *stats) {
  float module_mean = 0f;
  for (uint8_t mux = 0u; mux < NUM_MULTIPLEXERS; mux++) {
    for (uint8_t ch = 0u; ch < NUM_MUX_CHANNELS; ch++) {
      float mean = Calculate_Channel_Mean(mux, ch);
      module_mean += mean;

      if (mean > stats->max) {
        stats->max_temp = mean;
        stats->max_channel = ch;
      }

      if (mean < stats->min) {
        stats->min_temp = mean;
        stats->min_channel = ch;
      }
    }
  }
  stats->avg_temp = module_mean / NUM_MUX_CHANNELS;
}

/* ---------------------------------------------------------------------------
 * CAN_Init_Filter()
 * Configures CAN hardware filter to accept all incoming messages.
 * ---------------------------------------------------------------------------*/
static void CAN_Init_Filter(void) {
  CAN_FilterTypeDef f = {0};
  f.FilterActivation = CAN_FILTER_ENABLE;
  f.FilterBank = 0u;
  f.FilterFIFOAssignment = CAN_RX_FIFO0;
  f.FilterIdHigh = 0x0000u;
  f.FilterIdLow = 0x0000u;
  f.FilterMaskIdHigh = 0x0000u;
  f.FilterMaskIdLow = 0x0000u;
  f.FilterMode = CAN_FILTERMODE_IDMASK;
  f.FilterScale = CAN_FILTERSCALE_32BIT;
  f.SlaveStartFilterBank = 14u;

  if (HAL_CAN_ConfigFilter(&hcan, &f) != HAL_OK)
    Error_Handler();
}

/**
 * @brief Send temperature data following J1939 Thermistor Module format
 * @param module_number Thermistor Module number (which board/module)
 * @param stats Pointer to temperature statistics
 * @return HAL status
 *
 * CAN Message Format (ID: 0x1839F380):
 * Byte 0: Thermistor Module Number
 * Byte 1: Lowest temperature (int8_t, 1°C units)
 * Byte 2: Highest temperature (int8_t, 1°C units)
 * Byte 3: Average temperature (int8_t, 1°C units)
 * Byte 4: Number of enabled thermistors
 * Byte 5: Highest thermistor ID (zero-based)
 * Byte 6: Lowest thermistor ID (zero-based)
 * Byte 7: Checksum (sum of bytes 0-6 + 0x39 + length)
 */
static HAL_StatusTypeDef
CAN_SendTemperatureStatistics(TempStatistics_t *stats) {
  TxHeader.StdId = 0x380;      // Note: Full ID is 0x1839F380 (29-bit extended)
  TxHeader.ExtId = 0x1839F380; // Use extended ID format
  TxHeader.RTR = CAN_RTR_DATA;
  TxHeader.IDE = CAN_ID_EXT; // Extended ID, not standard!
  TxHeader.DLC = 8u;
  TxHeader.TransmitGlobalTime = DISABLE;

  // Convert temperatures to 8-bit signed integers (1°C resolution)
  // Clamp to int8_t range: -128°C to +127°C
  int8_t lowest_temp =
      (int8_t)fmax(-128.0f, fmin(127.0f, roundf(stats->min_temp)));
  int8_t highest_temp =
      (int8_t)fmax(-128.0f, fmin(127.0f, roundf(stats->max_temp)));
  int8_t average_temp =
      (int8_t)fmax(-128.0f, fmin(127.0f, roundf(stats->avg_temp)));

  // Pack data according to J1939 format
  TxData[0] = 1;                     // Thermistor Module Number
  TxData[1] = (uint8_t)lowest_temp;  // Lowest temperature (int8_t as uint8_t)
  TxData[2] = (uint8_t)highest_temp; // Highest temperature
  TxData[3] = (uint8_t)average_temp; // Average temperature
  TxData[4] = stats->num_enabled;    // Number of thermistors enabled
  TxData[5] = stats->max_channel;    // Highest thermistor ID (zero-based)
  TxData[6] = stats->min_channel;    // Lowest thermistor ID (zero-based)

  // Calculate checksum: sum of all bytes + 0x39 + message length
  uint8_t checksum = 0x39 + TxHeader.DLC; // Start with 0x39 + length (8)
  for (uint8_t i = 0; i < 7; i++) {
    checksum += TxData[i];
  }
  TxData[7] = checksum; // Checksum 8-bit

  return HAL_CAN_AddTxMessage(&hcan, &TxHeader, TxData, &TxMailbox);
}

